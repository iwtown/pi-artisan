{
  "name": "pi-artisan",
  "version": "2.3.0",
  "description": "Pi Agent artisan quality gate — manages skills, extensions, prompts, packages, and themes quality for the human-packaged capability track.",
  "keywords": [
    "pi-package",
    "pi-agent",
    "extension",
    "meta-validator",
    "quality-gate",
    "skill-management"
  ],
  "dependencies": {
    "@earendil-works/pi-coding-agent": ">=0.78.0",
    "typebox": "*"
  },
  "engines": {
    "node": ">=18"
  },
  "pi": {
    "extensions": [
      "src/index.ts"
    ],
    "skills": []
  },
  "scripts": {
    "test": "vitest run && node --check src/index.ts",
    "test:watch": "vitest",
    "typecheck": "npx tsc --noEmit",
    "build": "npx tsc"
  },
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/wtown/pi-artisan.git"
  },
  "devDependencies": {
    "vitest": "^4.1.8"
  }
}
